# apple-rag-docs-free — local environment template
# Copy to .env and fill in your values. Never commit .env.

# ─── Required ────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/apple_rag
DEEPINFRA_API_KEY=

# ─── Optional ────────────────────────────────────────────
PORT=8787
LOG_LEVEL=info

# ─── Collector ───────────────────────────────────────────
COLLECTOR_BATCH_SIZE=10
COLLECTOR_ADMIN_TOKEN=

# ─── Retrieval provider overrides (optional) ─────────────
# Override to point at a self-hosted OpenAI-compatible embedding/reranker API.
# Leave empty to use DeepInfra defaults.
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
RERANKER_BASE_URL=
RERANKER_MODEL_PRIMARY=
RERANKER_MODEL_FALLBACK=
