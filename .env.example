# apple-rag-docs-free - local environment template
# Copy to .env and fill in your values. Never commit .env.

# --- Required --------------------------------------------
DATABASE_URL=postgres://localhost:5432/apple_rag

# --- Server ----------------------------------------------
PORT=8787
LOG_LEVEL=info

# Optional bearer token for the MCP endpoint. If set, every POST /mcp request
# must include:   Authorization: Bearer <same-value>
# Leave empty to keep /mcp open (fine for local dev; required before exposing
# the server publicly).
MCP_AUTH_TOKEN=

# --- Collector -------------------------------------------
COLLECTOR_BATCH_SIZE=10
COLLECTOR_ADMIN_TOKEN=

# --- Embeddings (default: local Ollama) ------------------
# Any OpenAI-compatible endpoint works. Default points at Ollama.
# Run:  ollama pull nomic-embed-text
# nomic-embed-text outputs 768-dim vectors (matches default EMBEDDING_DIM).
# If you switch models, update EMBEDDING_DIM AND run a fresh migration
# (halfvec(N) is baked into the schema).
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Reranker (optional) ---------------------------------
# Ollama has no reranker. Leaving RERANKER_ENABLED=false means results come
# back in the hybrid-merge order (embedding cosine + keyword). Quality is
# still solid for most queries; you can turn this on later.
#
# Options when enabling:
#  [1] DeepInfra hosted (requires DEEPINFRA_API_KEY below)
#  [2] Self-hosted text-embeddings-inference with BAAI/bge-reranker-v2-m3
RERANKER_ENABLED=false
RERANKER_BASE_URL=https://api.deepinfra.com
RERANKER_MODEL_PRIMARY=Qwen/Qwen3-Reranker-8B
RERANKER_MODEL_FALLBACK=Qwen/Qwen3-Reranker-4B

# Only required if RERANKER_ENABLED=true AND RERANKER_BASE_URL is DeepInfra.
DEEPINFRA_API_KEY=
